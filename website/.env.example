# Configuration exemple pour Mastermind Sri Lanka Event Page
# Copier ce fichier en .env.local et remplir vos valeurs

# Configuration du site
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=HyperGrowth

# API endpoints (adapter selon votre backend)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_SECRET_KEY=your_secret_key_here

# Services d'inscription (adapter selon votre plateforme)
NEXT_PUBLIC_FORM_ID=your_form_id
NEXT_PUBLIC_FORM_SECRET=your_form_secret

# Analytics (optionnel)
NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id

# Email notifications (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@hypergrowth.fr

# CMS (si utilisation de Contentful, Strapi, etc.)
NEXT_PUBLIC_CMS_URL=https://api.contentful.com
CMS_ACCESS_TOKEN=your_cms_token

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_FORMS=false
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Images
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_IMAGE_FORMATS=avif,webp

# Sentry (error tracking, optionnel)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456